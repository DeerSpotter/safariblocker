<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>items</key>
	<array>

		<dict>
			<key>cell</key>
			<string>PSSwitchCell</string>
			<key>default</key>
			<true/>
			<key>defaults</key>
			<string>com.deerspotter.safariblocker</string>
			<key>key</key>
			<string>showBagelMenu</string>
			<key>label</key>
			<string>Show Blocked Message</string>
			<key>PostNotification</key>
			<string>com.deerspotter.safariblocker.settingschanged</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Whitelisted Domains</string>
			<key>footerText</key>
			<string>Tap Specify Whitelisted Domains, then press + to manually add a domain. Submit saves it, Cancel closes the popup.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSLinkListCell</string>
			<key>detail</key>
			<string>PSListItemsController</string>
			<key>label</key>
			<string>Specify Whitelisted Domains...</string>
			<key>action</key>
			<string>launchAllowedDomainOptions</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Blocked Domains</string>
			<key>footerText</key>
			<string>Tap Specify Blocked Domains, then press + to manually add a domain. Submit saves it, Cancel closes the popup.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSLinkListCell</string>
			<key>detail</key>
			<string>PSListItemsController</string>
			<key>label</key>
			<string>Specify Blocked Domains...</string>
			<key>action</key>
			<string>launchBlockedDomainOptions</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Blocked URLs</string>
			<key>footerText</key>
			<string>Tap Specify Blocked URLs, then press + to manually add a URL. Submit saves it, Cancel closes the popup.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSLinkListCell</string>
			<key>detail</key>
			<string>PSListItemsController</string>
