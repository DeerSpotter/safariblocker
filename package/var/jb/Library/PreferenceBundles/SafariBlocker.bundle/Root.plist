			<string>Specify Blocked URLs...</string>
			<key>action</key>
			<string>launchBlockedURLOptions</string>
		</dict>

		<dict>
			<key>cell</key>
			<string>PSGroupCell</string>
			<key>label</key>
			<string>Backup and Restore</string>
			<key>footerText</key>
			<string>Export saves whitelisted domains, blocked domains, and blocked URLs to one JSON backup file. Import restores those three lists from a SafariBlocker backup file.</string>
		</dict>
		<dict>
			<key>cell</key>
			<string>PSButtonCell</string>
			<key>label</key>
			<string>Export List Backup</string>
			<key>action</key>
